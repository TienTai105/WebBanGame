# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/webbandb?retryWrites=true&w=majority

# JWT Secrets
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Frontend URL
CLIENT_URL=http://localhost:5173

# Payment Gateway (Week 2)
MOMO_ACCESS_KEY=your_momo_key
MOMO_SECRET_KEY=your_momo_secret
MOMO_PARTNER_CODE=your_partner_code

VNPAY_TERMINAL_ID=your_terminal_id
VNPAY_HASH_SECRET=your_hash_secret

# Email Configuration
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_mailtrap_user
EMAIL_PASS=your_mailtrap_pass
EMAIL_FROM=noreply@webbandb.com

# Cloudinary (for images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
