              "raw": "{\n  \"orderItems\": [\n    {\n      \"product\": \"{{PRODUCT_ID}}\",\n      \"quantity\": 1,\n      \"variantSku\": \"RE-PS5-004\"\n    }\n  ],\n  \"totalPrice\": 1199990,\n  \"discountAmount\": 0,\n  \"shippingFee\": 0,\n  \"finalPrice\": 1199990,\n  \"paymentMethod\": \"COD\",\n  \"shippingAddress\": {\n    \"name\": \"John Doe\",\n    \"address\": \"123 Main Street\",\n    \"city\": \"Ho Chi Minh City\",\n    \"district\": \"D1\",\n    \"ward\": \"W1\",\n    \"phone\": \"0987654321\",\n    \"email\": \"john@test.com\"\n  }\n}"
