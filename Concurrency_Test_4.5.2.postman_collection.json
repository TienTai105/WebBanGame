{
  "info": {
    "name": "🧪 Spec 4.5.2 - Concurrent Order Placement (2 Users)",
    "description": "Test concurrent order placement: User A and User B both try to order PS5-ASIA (available=1) at the same time. Expected: 1 success (201), 1 failure (409)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "📋 [SETUP] Create Users & Product",
      "item": [
        {
          "name": "1. Register User A",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log('User A registration response:', pm.response.code)"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"userA.{{$timestamp}}@test.com\", \"password\": \"TestPass@123456\", \"name\": \"User A Concurrent\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "2. Login User A",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var token = pm.response.json().data.accessToken;",
                  "pm.environment.set('tokenA', token);",
                  "console.log('✅ User A Token saved')"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"userA.{{$timestamp}}@test.com\", \"password\": \"TestPass@123456\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "3. Register User B",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"userB.{{$timestamp}}@test.com\", \"password\": \"TestPass@123456\", \"name\": \"User B Concurrent\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "4. Login User B",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var token = pm.response.json().data.accessToken;",
                  "pm.environment.set('tokenB', token);",
                  "console.log('✅ User B Token saved')"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"userB.{{$timestamp}}@test.com\", \"password\": \"TestPass@123456\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "5. Create Product PS5-ASIA",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var productId = pm.response.json().data._id;",
                  "pm.environment.set('productId', productId);",
                  "console.log('✅ Product ID saved:', productId)"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{tokenA}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"PlayStation 5 Concurrency Test {{$timestamp}}\", \"description\": \"For test 4.5.2\", \"categoryId\": \"507f1f77bcf86cd799439011\", \"minPrice\": 45000000, \"maxPrice\": 45000000, \"variants\": [{\"sku\": \"PS5-ASIA\", \"name\": \"Standard Edition\", \"price\": 45000000, \"cost\": 40000000, \"discount\": 0, \"finalPrice\": 45000000, \"status\": \"active\"}]}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "6. Set Inventory = 1",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{tokenA}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"productId\": \"{{productId}}\", \"variantSku\": \"PS5-ASIA\", \"available\": 1, \"reserved\": 0, \"sold\": 0, \"damaged\": 0}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/inventory",
              "host": ["{{baseUrl}}"],
              "path": ["api", "inventory"]
            }
          }
        }
      ]
    },
    {
      "name": "⚡ [TEST 4.5.2] Concurrent Order (Run both simultaneously!)",
      "item": [
        {
          "name": "[1/2] User A - Place Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const status = pm.response.code;",
                  "const body = pm.response.json();",
                  "console.log('');",
                  "console.log('═══════════════════════════════════════');",
                  "console.log('✅ USER A RESPONSE');",
                  "console.log('═══════════════════════════════════════');",
                  "console.log('Status Code:', status);",
                  "console.log('Message:', body.message);",
                  "if (body.data?.orderCode) {",
                  "  console.log('Order Code:', body.data.orderCode);",
                  "  pm.environment.set('orderIdA', body.data._id);",
                  "}",
                  "console.log('');",
                  "pm.test('User A - Expect 201 (Success)', function() {",
                  "  pm.expect(pm.response.code).to.equal(201);",
                  "})"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{tokenA}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"orderItems\": [{\"product\": \"{{productId}}\", \"variantSku\": \"PS5-ASIA\", \"quantity\": 1, \"priceAtPurchase\": 45000000}], \"shippingAddress\": {\"name\": \"User A\", \"phone\": \"0901234561\", \"email\": \"userA@test.com\", \"address\": \"123 Test Street\", \"city\": \"Ho Chi Minh\", \"postalCode\": \"70000\", \"country\": \"Vietnam\"}, \"paymentMethod\": \"COD\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            }
          }
        },
        {
          "name": "[2/2] User B - Place Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const status = pm.response.code;",
                  "const body = pm.response.json();",
                  "console.log('');",
                  "console.log('═══════════════════════════════════════');",
                  "console.log('❌ USER B RESPONSE');",
                  "console.log('═══════════════════════════════════════');",
                  "console.log('Status Code:', status);",
                  "console.log('Message:', body.message);",
                  "if (body.data?.available !== undefined) {",
                  "  console.log('Available Stock:', body.data.available);",
                  "}",
                  "console.log('');",
                  "pm.test('User B - Expect 409 (Conflict)', function() {",
                  "  pm.expect(pm.response.code).to.equal(409);",
                  "})"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{tokenB}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"orderItems\": [{\"product\": \"{{productId}}\", \"variantSku\": \"PS5-ASIA\", \"quantity\": 1, \"priceAtPurchase\": 45000000}], \"shippingAddress\": {\"name\": \"User B\", \"phone\": \"0901234562\", \"email\": \"userB@test.com\", \"address\": \"123 Test Street\", \"city\": \"Ho Chi Minh\", \"postalCode\": \"70000\", \"country\": \"Vietnam\"}, \"paymentMethod\": \"COD\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "tokenA",
      "value": "",
      "type": "string"
    },
    {
      "key": "tokenB",
      "value": "",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderIdA",
      "value": "",
      "type": "string"
    }
  ]
}
